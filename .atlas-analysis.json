  "keyFeatures": [
    "Daily, monthly, weekly, and session-based usage reports",
    "5-hour billing blocks tracking with active block monitoring",
    "Cost calculation with multiple modes (auto/calculate/display)",
    "JSON output format for programmatic consumption",
    "Model Context Protocol (MCP) server integration",
    "Per-model cost breakdown and cache token tracking",
    "Multi-project/instance support with filtering",
    "Custom Claude data directory paths",
    "Timezone and locale customization",
    "Configuration files with JSON schema validation",
    "Statusline integration for status bar hooks",
    "Ultra-small bundle size for fast execution"
  ],
  "publicApiSurface": [
    "ccusage daily - Daily usage report",
    "ccusage monthly - Monthly usage report",
    "ccusage weekly - Weekly usage report",
    "ccusage session - Session-based usage report",
    "ccusage blocks - 5-hour billing blocks report",
    "ccusage statusline - Compact status line display",
    "loadDailyUsageData() - Load and parse usage data",
    "calculateTotals() - Calculate token and cost totals",
    "loadConfig() - Load configuration from files"
  ]
}
